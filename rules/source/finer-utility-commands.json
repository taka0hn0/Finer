      "description": "Normal/Visual Mode: Start gg sequence",
      "from": {
        "key_code": "g"
      },
      "parameters": {
        "basic.to_delayed_action_delay_milliseconds": 1000
      },
      "to": [
        {
          "set_variable": {
            "name": "finder_g_prefix",
            "value": 1
          }
        }
      ],
      "to_delayed_action": {
        "to_if_canceled": [
          {
            "set_variable": {
              "name": "finder_g_prefix",
              "value": 0
            }
          }
        ],
        "to_if_invoked": [
          {

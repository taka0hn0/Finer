{
  "description": "Finer Utility Commands",
  "manipulators": [
    {
      "conditions": [
        {
          "bundle_identifiers": [
            "^com\\.apple\\.finder$"
          ],
          "type": "frontmost_application_if"
        },
        {
          "expression": "accessibility.focused_ui_element.role_string like 'AXText*'",
          "type": "expression_unless"
        },
        {
          "name": "finder_visual_mode",
          "type": "variable_if",
          "value": 1
        },
        {
          "name": "finder_g_prefix",
          "type": "variable_if",
          "value": 1
        }
      ],
      "description": "Visual Mode: Press gg to extend selection to first or Grid column top",
      "from": {
        "key_code": "g"
      },
      "to": [
        {
          "shell_command": "exec $HOME/.local/libexec/finder-vim/finder_ax_move visual-first >/dev/null 2>&1"
        },
        {
          "set_variable": {
            "name": "finder_g_prefix",
            "value": 0
          }
        }
      ],
      "type": "basic"
    },
    {
      "conditions": [
        {
          "bundle_identifiers": [
            "^com\\.apple\\.finder$"
          ],

          "name": "finder_visual_mode",
          "type": "variable_if",
          "value": 1
        }
      ],
      "description": "Visual Mode: Press G to extend selection to last or Grid column bottom",
      "from": {
        "key_code": "g",
        "modifiers": {
          "mandatory": [
            "shift"
          ],
          "optional": [
            "caps_lock"
          ]
        }
      },
      "to": [
        {
          "shell_command": "exec $HOME/.local/libexec/finder-vim/finder_ax_move visual-last >/dev/null 2>&1"
        }
      ],
      "type": "basic"
    },
    {
